{
  "rules": {
    "hospitals": {
      ".read": true,
      "$hospitalId": {
        ".write": "auth.token.role === 'superadmin' || (auth.token.role === 'hospitaladmin' && auth.token.hospitalId === $hospitalId)",
        "fleet": {
          ".write": "auth.token.role === 'superadmin' || ((auth.token.role === 'hospitaladmin' || auth.token.role === 'fleetofficer') && auth.token.hospitalId === $hospitalId)"
        },
        "drivers": {
          "$driverId": {
            ".write": "auth.uid === $driverId || auth.token.role === 'superadmin' || ((auth.token.role === 'hospitaladmin' || auth.token.role === 'fleetofficer') && auth.token.hospitalId === $hospitalId)"
          }
        }
      }
    },
    "admin": {
      ".read": "auth.token.role === 'superadmin'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid || auth.token.role === 'superadmin'"
      }
    },
    "drivers": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth.uid === $uid || auth.token.role === 'superadmin' || auth.token.role === 'hospitaladmin' || auth.token.role === 'fleetofficer'"
      }
    },
    "transfer_requests": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": [
        "driverId",
        "fromHospitalId",
        "toHospitalId"
      ]
    },
    "patient_records": {
      ".read": "auth.token.role === 'superadmin' || auth.token.role === 'hospitaladmin'",
      ".write": "auth.token.role === 'superadmin' || auth.token.role === 'hospitaladmin'",
      ".indexOn": [
        "hospitalId"
      ]
    },
    "analytics": {
      ".read": "auth.token.role === 'superadmin' || auth.token.role === 'hospitaladmin'",
      ".write": "auth.token.role === 'superadmin' || auth.token.role === 'hospitaladmin'",
      ".indexOn": [
        "hospitalId"
      ]
    },
    "driver_locations": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth.uid === $uid || auth.token.role === 'superadmin'"
      }
    },
    "trip_history": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth.uid === $uid || auth.token.role === 'superadmin'"
      }
    }
  }
}