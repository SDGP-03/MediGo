{
  "rules": {
    "admin": {
      "$uid": {
        ".read": "auth.uid === $uid || auth.token.role === 'superadmin'",
        ".write": "auth.token.role === 'superadmin'"
      }
    },
    "drivers": {
      "$uid": {
        ".read": "auth.uid === $uid || auth.token.role === 'superadmin'",
        ".write": "auth.uid === $uid || auth.token.role === 'superadmin'"
      }
    },
    "hospitals": {
      "$hospital_id": {
        ".read": "auth.token.role === 'superadmin' || auth.token.hospitalId === $hospital_id",
        ".write": "auth.token.role === 'superadmin' || (auth.token.role === 'admin' && auth.token.hospitalId === $hospital_id)",
        
        "drivers": {
          "$driver_uid": {
            ".read": "auth.uid === $driver_uid || auth.token.role === 'superadmin' || auth.token.hospitalId === $hospital_id",
            ".write": "auth.uid === $driver_uid || auth.token.role === 'superadmin' || (auth.token.role === 'admin' && auth.token.hospitalId === $hospital_id)"
          }
        },
        
        "fleet_officers": {
           ".write": "auth.token.role === 'superadmin' || (auth.token.role === 'admin' && auth.token.hospitalId === $hospital_id)"
        },
        
        "fleet": {
           ".write": "auth.token.role === 'superadmin' || ((auth.token.role === 'admin' || auth.token.role === 'fleet_officer' || auth.token.role === 'driver') && auth.token.hospitalId === $hospital_id)"
        }
      }
    }
  }
}
